{
  "name": "cookies-tiny",
  "version": "0.1.0",
  "description": "Tiny RFC 6265 cookie parser and serializer. Set-Cookie parsing, SameSite/Secure/HttpOnly, URL-encoding. Zero dependencies.",
  "keywords": ["cookie", "rfc6265", "http", "set-cookie", "samesite"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": { "node": ">=18" },
  "author": { "name": "Vlad Bordei", "email": "bordeivlad@gmail.com", "url": "https://github.com/p-vbordei" },
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/p-vbordei/cookies-tiny.git" },
  "bugs": { "url": "https://github.com/p-vbordei/cookies-tiny/issues" },
  "homepage": "https://github.com/p-vbordei/cookies-tiny#readme",
  "devDependencies": { "typescript": "^5.5.0", "vitest": "^2.0.0" }
}
